{
  "name": "agentmemorymcp",
  "title": "AgentMemory Mesh",
  "description": "A paid remote MCP for agent memory MCP, built to return verdicts, receipts, usage logs, and audit-ready JSON for agent and CI workflows.",
  "version": "1.0.0",
  "websiteUrl": "https://agentmemorymcp.clauxel.com/",
  "documentationUrl": "https://agentmemorymcp.clauxel.com/mcp/",
  "endpointUrl": "https://agentmemorymcp.clauxel.com/mcp",
  "transport": "streamable-http",
  "authentication": {
    "type": "bearer",
    "required": true,
    "header": "Authorization",
    "format": "Bearer <paid-token>"
  },
  "paidAccess": {
    "required": true,
    "checkoutUrl": "https://agentmemorymcp.clauxel.com/api/agent-checkout",
    "tokenStatusUrl": "https://agentmemorymcp.clauxel.com/api/mcp-token/status",
    "tokenClaimUrl": "https://agentmemorymcp.clauxel.com/api/mcp-token/claim",
    "defaultPlan": "team",
    "pricing": [
      {
        "id": "solo",
        "name": "Solo",
        "monthlyUsd": 25
      },
      {
        "id": "team",
        "name": "Team",
        "monthlyUsd": 89
      },
      {
        "id": "studio",
        "name": "Studio",
        "monthlyUsd": 229
      }
    ]
  },
